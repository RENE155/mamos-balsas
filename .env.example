# === MamosBalsas aplinkos kintamieji ===
# Nukopijuokite šį failą į `.env` ir įrašykite savo reikšmes.
# EXPO_PUBLIC_* kintamieji įkompiliuojami į programėlę.

# Supabase (autentifikacija + duomenų bazė)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI (pasakų generavimas)
EXPO_PUBLIC_OPENAI_API_KEY=

# ElevenLabs (balso klonavimas / sintezė)
EXPO_PUBLIC_ELEVENLABS_API_KEY=
EXPO_PUBLIC_ELEVENLABS_VOICE_ID=

# RevenueCat (prenumeratos)
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
